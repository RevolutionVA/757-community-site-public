---
import MainLayout from '../layouts/MainLayout.astro';

const inPersonCommunities = [
  {
    name: "757Makerspace Norfolk",
    url: "https://757makerspace.com",
    description: "Community workshop and prototyping center in Norfolk."
  },
  {
    name: "757 Makerspace Hampton",
    url: "https://757makerspace.com/hampton",
    description: "Community workshop and prototyping center in Hampton."
  }
];

const onlineCommunities = [
  {
    name: "757dev Slack",
    url: "https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ",
    description: "Slack community for developers in the 757 area."
  },
  {
    name: "757dev Discord",
    url: "https://discord.gg/bPGsCKBqWp",
    description: "Discord community for developers in the 757 area."
  }
];
---

<MainLayout
  title="Communities"
  description="Tech communities in the Hampton Roads area, both in-person and online."
>
  <div class="container">
    <h1>Communities</h1>
    <p>Tech communities in Hampton Roads &mdash; online and in person.</p>

    <h2>Online</h2>
    <ul class="community-list">
      {onlineCommunities.map((c) => (
        <li>
          <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
          {' '}&mdash; <span class="muted">{c.description}</span>
        </li>
      ))}
    </ul>

    <h2>In person</h2>
    <ul class="community-list">
      {inPersonCommunities.map((c) => (
        <li>
          <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
          {' '}&mdash; <span class="muted">{c.description}</span>
        </li>
      ))}
    </ul>
  </div>
</MainLayout>

<style>
  .community-list {
    list-style: none;
    padding: 0;
  }
  .community-list li {
    margin-bottom: 0.35rem;
  }
</style>
