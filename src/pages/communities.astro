---
import MainLayout from '../layouts/MainLayout.astro';

const inPersonCommunities = [
  { name: "757Makerspace Norfolk", url: "https://757makerspace.com", description: "A community workshop and prototyping center" },
  { name: "757 Makerspace Hampton", url: "https://757makerspace.com/hampton", description: "A community workshop and prototyping center in Hampton" }
];

const onlineCommunities = [
  { name: "757dev - Slack", url: "https://757dev.org", description: "A Slack community for developers in the 757 area" },
  { name: "757dev - Discord", url: "https://discord.gg/757dev", description: "A Discord community for developers in the 757 area" }
];
---

<MainLayout title="Communities" description="Connect with tech communities in the Hampton Roads area, both in-person and online.">
  <div class="page-hero">
    <h1>Communities</h1>
    <p>Connect with tech communities in Hampton Roads.</p>
  </div>

  <div class="sec">online</div>

  {onlineCommunities.map(c => (
    <div class="co">
      <div>
        <div class="cn"><a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a></div>
        <div class="cd">{c.description}</div>
      </div>
    </div>
  ))}

  <div class="sec">in-person</div>

  {inPersonCommunities.map(c => (
    <div class="co">
      <div>
        <div class="cn"><a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a></div>
        <div class="cd">{c.description}</div>
      </div>
    </div>
  ))}
</MainLayout>
