---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Thank You for Subscribing"
  description="Thank you for subscribing to the 757tech newsletter."
>
  <div class="sec">welcome to 757tech</div>

  <div class="content-block">
    <h2>Thanks for subscribing!</h2>
    <p>You'll now receive weekly updates on tech events, meetups, and happenings across Hampton Roads, plus exclusive offers for events like Hampton Roads DevFest and RevolutionConf.</p>
  </div>

  <div class="content-block">
    <p>Your first update is on its way. In the meantime:</p>
    <p>
      <a href="/calendar">View upcoming events</a> ·
      <a href="/meetups">Browse meetup groups</a> ·
      <a href="/get-involved">Get involved</a> ·
      <a href="/">Return home</a>
    </p>
  </div>
</MainLayout>
