---
import MainLayout from '../layouts/MainLayout.astro';
import calendarEvents from '../data/calendar-events.json';
import meetupsData from '../data/meetups-combined.json';

interface CalendarEvent {
  title: string;
  link: string;
  date: string;
  description: string;
  source: string;
  group: string;
  featuredEvent?: boolean;
}

const today = new Date();
today.setHours(0, 0, 0, 0);
const sixMonthsFromNow = new Date(today);
sixMonthsFromNow.setMonth(today.getMonth() + 6);

const upcomingEvents = (calendarEvents as CalendarEvent[])
  .filter((event) => {
    const eventDate = new Date(event.date);
    return eventDate >= today && eventDate <= sixMonthsFromNow;
  })
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const featuredEvents = upcomingEvents.filter((e) => e.featuredEvent === true);
const regularEvents = upcomingEvents.filter((e) => e.featuredEvent !== true);

function monthKey(date: Date): string {
  return date.toLocaleDateString('en-US', {
    timeZone: 'America/New_York',
    month: 'long',
    year: 'numeric',
  });
}

const eventsByMonth: Record<string, CalendarEvent[]> = {};
for (const event of regularEvents) {
  const key = monthKey(new Date(event.date));
  if (!eventsByMonth[key]) eventsByMonth[key] = [];
  eventsByMonth[key].push(event);
}
const monthsInOrder = Object.keys(eventsByMonth).sort((a, b) => {
  return new Date(a).getTime() - new Date(b).getTime();
});

function formatEventLine(dateString: string): string {
  const d = new Date(dateString);
  const datePart = d.toLocaleDateString('en-US', {
    timeZone: 'America/New_York',
    weekday: 'short',
    month: 'short',
    day: 'numeric',
  });
  const timePart = d
    .toLocaleTimeString('en-US', {
      timeZone: 'America/New_York',
      hour: 'numeric',
      minute: '2-digit',
    })
    .replace(/\s/g, '')
    .toLowerCase();
  return `${datePart} · ${timePart}`;
}

function findMeetupUrl(groupName: string): string | null {
  const meetup = meetupsData.find((m: any) => m.name === groupName);
  return meetup ? meetup.url : null;
}
---

<MainLayout
  title="Calendar"
  description="Upcoming tech events and meetups in Hampton Roads, Virginia for the next six months."
>
  <div class="container">
    <h1>Calendar</h1>
    <p>Upcoming tech events in Hampton Roads for the next six months.</p>
    <p class="muted">
      Want to add or update an event?
      <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/calendar-events.json" target="_blank" rel="noopener noreferrer">Edit the calendar data file on GitHub</a>.
    </p>

    {featuredEvents.length > 0 && (
      <>
        <h2>Featured</h2>
        <ul class="event-list">
          {featuredEvents.map((event) => {
            const groupUrl = findMeetupUrl(event.group);
            return (
              <li>
                <span class="event-when">{formatEventLine(event.date)}</span>{' '}
                <a href={event.link} target="_blank" rel="noopener noreferrer">{event.title}</a>
                {' '}&mdash;{' '}
                {groupUrl ? (
                  <a href={groupUrl} target="_blank" rel="noopener noreferrer" class="muted-link">{event.group}</a>
                ) : (
                  <span class="muted">{event.group}</span>
                )}
              </li>
            );
          })}
        </ul>
      </>
    )}

    <h2>Upcoming events</h2>
    {regularEvents.length === 0 ? (
      <p class="muted">No events currently scheduled in the next six months. Check the <a href="/meetups">meetups page</a> for group links.</p>
    ) : (
      monthsInOrder.map((month) => (
        <>
          <h3>{month}</h3>
          <ul class="event-list">
            {eventsByMonth[month].map((event) => {
              const groupUrl = findMeetupUrl(event.group);
              return (
                <li>
                  <span class="event-when">{formatEventLine(event.date)}</span>{' '}
                  <a href={event.link} target="_blank" rel="noopener noreferrer">{event.title}</a>
                  {' '}&mdash;{' '}
                  {groupUrl ? (
                    <a href={groupUrl} target="_blank" rel="noopener noreferrer" class="muted-link">{event.group}</a>
                  ) : (
                    <span class="muted">{event.group}</span>
                  )}
                </li>
              );
            })}
          </ul>
        </>
      ))
    )}
  </div>
</MainLayout>

<style>
  .event-list {
    list-style: none;
    padding: 0;
  }

  .event-list li {
    margin-bottom: 0.3rem;
  }

  .event-when {
    display: inline-block;
    min-width: 12rem;
    color: #666;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.85rem;
  }

  .muted-link {
    color: #0000CC;
  }

  @media (max-width: 600px) {
    .event-when {
      display: block;
      min-width: 0;
      margin-bottom: 0.1rem;
    }
  }
</style>
