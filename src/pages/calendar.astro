---
import MainLayout from '../layouts/MainLayout.astro';
import EventRow from '../components/EventRow.astro';
import calendarEvents from '../data/calendar-events.json';
import { formatShortDate } from '../utils/formatDate';

interface CalendarEvent {
  title: string;
  link: string;
  date: string;
  description: string;
  source: string;
  group: string;
  featuredEvent?: boolean;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const sixMonthsFromNow = new Date(today);
sixMonthsFromNow.setMonth(today.getMonth() + 6);

const upcomingEvents = calendarEvents
  .filter((event: CalendarEvent) => {
    const eventDate = new Date(event.date);
    return eventDate >= today && eventDate <= sixMonthsFromNow;
  })
  .sort((a: CalendarEvent, b: CalendarEvent) => {
    return new Date(a.date).getTime() - new Date(b.date).getTime();
  });

const featuredEvents = upcomingEvents.filter((event: CalendarEvent) => event.featuredEvent === true);
const regularEvents = upcomingEvents.filter((event: CalendarEvent) => event.featuredEvent !== true);

const eventsByMonth: Record<string, CalendarEvent[]> = {};
regularEvents.forEach((event: CalendarEvent) => {
  const date = new Date(event.date);
  const monthYear = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  if (!eventsByMonth[monthYear]) eventsByMonth[monthYear] = [];
  eventsByMonth[monthYear].push(event);
});

const monthsInOrder = Object.keys(eventsByMonth).sort((a, b) => {
  return new Date(a).getTime() - new Date(b).getTime();
});


---

<MainLayout
  title="Calendar"
  description="Stay updated with tech events in Hampton Roads, Virginia. View our comprehensive calendar of meetups, conferences, and workshops."
>
  <div class="page-hero">
    <h1>Calendar</h1>
    <p>Upcoming tech events and meetups in Hampton Roads for the next six months.
      <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/calendar-events.json" target="_blank" rel="noopener noreferrer">Add an event</a>
    </p>
  </div>

  {featuredEvents.length > 0 && (
    <div class="sec">featured events</div>
  )}
  {featuredEvents.map((event: CalendarEvent) => (
    <EventRow
      date={formatShortDate(event.date)}
      title={event.title}
      link={event.link}
      tags={[event.group, 'featured']}
      highlightedTags={['featured']}
    />
  ))}

  {regularEvents.length === 0 ? (
    <Fragment>
      <div class="sec">upcoming events</div>
      <div class="row">
        <span class="dt"></span>
        <span class="ti">No events scheduled. <a href="/meetups">View meetup groups</a></span>
        <span class="lo"></span>
      </div>
    </Fragment>
  ) : (
    monthsInOrder.map(monthYear => (
      <Fragment>
        <div class="sec">{monthYear}</div>
        {eventsByMonth[monthYear].map((event: CalendarEvent) => (
          <EventRow
            date={formatShortDate(event.date)}
            title={event.title}
            link={event.link}
            tags={[event.group]}
          />
        ))}
      </Fragment>
    ))
  )}
</MainLayout>
