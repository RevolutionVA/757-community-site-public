---
import MainLayout from '../layouts/MainLayout.astro';
import conferencesData from '../data/conferences.json';

interface Conference {
  name: string;
  url: string;
  description: string;
  date: string;
  endDate?: string;
  location: string;
  tags: string[];
  coverImage?: string;
}

function parseLocalDate(dateString: string): Date {
  return new Date(dateString.includes('T') ? dateString : `${dateString}T12:00:00`);
}

function formatDate(dateString: string): string {
  const dateToFormat = dateString.includes('T') ? dateString : `${dateString}T12:00:00`;
  return new Date(dateToFormat).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}

function formatRange(conf: Conference): string {
  if (conf.endDate && conf.endDate !== conf.date) {
    return `${formatDate(conf.date)} – ${formatDate(conf.endDate)}`;
  }
  return formatDate(conf.date);
}

const currentDate = new Date();

const upcomingConferences = (conferencesData as Conference[])
  .filter((c) => parseLocalDate(c.date) > currentDate)
  .sort((a, b) => parseLocalDate(a.date).getTime() - parseLocalDate(b.date).getTime());

const pastConferences = (conferencesData as Conference[])
  .filter((c) => parseLocalDate(c.date) <= currentDate)
  .sort((a, b) => parseLocalDate(b.date).getTime() - parseLocalDate(a.date).getTime());
---

<MainLayout
  title="Conferences"
  description="Tech conferences in and around Hampton Roads, Virginia. Upcoming and past events worth the trip."
>
  <div class="container">
    <h1>Conferences</h1>
    <p>Tech conferences in and around Hampton Roads.</p>
    <p class="muted">
      Missing a conference?
      <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/conferences.json" target="_blank" rel="noopener noreferrer">Edit the conferences data file on GitHub</a>.
    </p>

    <h2>Upcoming</h2>
    {upcomingConferences.length > 0 ? (
      <ul class="conference-list">
        {upcomingConferences.map((c) => (
          <li>
            <span class="conf-date">{formatRange(c)}</span>{' '}
            <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
            {' '}&mdash; <span class="muted">{c.location}</span>
            {c.description && <div class="conf-desc">{c.description}</div>}
            {c.tags.length > 0 && <div class="muted conf-tags">{c.tags.join(', ')}</div>}
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">None currently scheduled. Join the community <a href="https://757dev.org">Slack</a> to hear first.</p>
    )}

    <h2>Past</h2>
    {pastConferences.length > 0 ? (
      <ul class="conference-list">
        {pastConferences.map((c) => (
          <li>
            <span class="conf-date">{formatRange(c)}</span>{' '}
            <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
            {' '}&mdash; <span class="muted">{c.location}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">(none)</p>
    )}

    <h2>Want to organize one?</h2>
    <p>
      Reach out to <a href="https://revolutionva.org">RevolutionVA</a> for guidance and resources,
      or see <a href="/get-involved">get involved</a>.
    </p>
  </div>
</MainLayout>

<style>
  .conference-list {
    list-style: none;
    padding: 0;
  }

  .conference-list > li {
    margin-bottom: 0.75rem;
  }

  .conf-date {
    display: inline-block;
    min-width: 14rem;
    color: #666;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.85rem;
  }

  .conf-desc {
    margin-left: 14rem;
    margin-top: 0.2rem;
  }

  .conf-tags {
    margin-left: 14rem;
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .conf-date {
      display: block;
      min-width: 0;
      margin-bottom: 0.1rem;
    }
    .conf-desc, .conf-tags {
      margin-left: 0;
    }
  }
</style>
