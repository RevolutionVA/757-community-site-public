---
import MainLayout from '../layouts/MainLayout.astro';
import EventRow from '../components/EventRow.astro';

import conferencesData from '../data/conferences.json';

interface Conference {
  name: string;
  url: string;
  description: string;
  date: string;
  endDate?: string;
  location: string;
  tags: string[];
  coverImage?: string;
}

function parseLocalDate(dateString: string): Date {
  return new Date(dateString.includes('T') ? dateString : `${dateString}T12:00:00`);
}

const currentDate = new Date();

const upcomingConferences = (conferencesData as Conference[])
  .filter(c => parseLocalDate(c.date) > currentDate)
  .sort((a, b) => parseLocalDate(a.date).getTime() - parseLocalDate(b.date).getTime());

const pastConferences = (conferencesData as Conference[])
  .filter(c => parseLocalDate(c.date) <= currentDate)
  .sort((a, b) => parseLocalDate(b.date).getTime() - parseLocalDate(a.date).getTime());

function formatDate(dateString: string): string {
  const d = parseLocalDate(dateString);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
---

<MainLayout
  title="Conferences"
  description="Discover tech conferences in and around Hampton Roads, Virginia. Find upcoming developer, design, and technology events."
>
  <div class="page-hero">
    <h1>Conferences</h1>
    <p>Tech conferences in the Hampton Roads area.
      <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/conferences.json" target="_blank" rel="noopener noreferrer">Add a conference</a>
    </p>
  </div>

  <div class="sec">upcoming conferences</div>

  {upcomingConferences.length > 0 ? (
    upcomingConferences.map(conf => (
      <div class="co">
        <div>
          <div class="cn"><a href={conf.url} target="_blank" rel="noopener noreferrer">{conf.name}</a></div>
          <div class="cd">
            {conf.description}
            <span class="tg" style="margin-left: 6px;">
              {conf.tags.map(tag => (
                <span class="t">{tag}</span>
              ))}
            </span>
          </div>
        </div>
        <span class="cc">{formatDate(conf.date)} · {conf.location}</span>
      </div>
    ))
  ) : (
    <div class="row">
      <span class="dt"></span>
      <span class="ti">None currently scheduled — check back soon or join <a href="https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ">Slack</a> for updates</span>
      <span class="lo"></span>
    </div>
  )}

  <div class="sec">past conferences</div>

  {pastConferences.map(conf => (
    <div class="co">
      <div>
        <div class="cn"><a href={conf.url} target="_blank" rel="noopener noreferrer">{conf.name}</a></div>
        <div class="cd">{conf.description}</div>
      </div>
      <span class="cc">{formatDate(conf.date)} · {conf.location}</span>
    </div>
  ))}

  <div class="sec">want to organize a conference?</div>

  <div class="content-block">
    <p>Interested in organizing a tech conference in Hampton Roads? Reach out to <a href="https://revolutionva.org">RevolutionVA</a> for guidance and resources, or <a href="/get-involved">get involved</a> with the community.</p>
  </div>
</MainLayout>
