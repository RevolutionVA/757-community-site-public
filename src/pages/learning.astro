---
import MainLayout from '../layouts/MainLayout.astro';

const educationalInstitutions = [
  { name: "Old Dominion University", url: "https://www.odu.edu/", description: "Public research university in Norfolk" },
  { name: "Tidewater Community College", url: "https://www.tcc.edu/", description: "Community college with multiple campuses" },
  { name: "ECPI", url: "https://www.ecpi.edu/", description: "Private university focused on technology" },
  { name: "Hampton University", url: "https://www.hamptonu.edu/", description: "Private university in Hampton" }
];
---

<MainLayout title="Learning" description="Discover educational resources and institutions in the Hampton Roads area to grow your tech skills.">
  <div class="page-hero">
    <h1>Learning</h1>
    <p>Educational resources and institutions in Hampton Roads.</p>
  </div>

  <div class="sec">educational institutions</div>

  {educationalInstitutions.map(inst => (
    <div class="co">
      <div>
        <div class="cn"><a href={inst.url} target="_blank" rel="noopener noreferrer">{inst.name}</a></div>
        <div class="cd">{inst.description}</div>
      </div>
    </div>
  ))}
</MainLayout>
