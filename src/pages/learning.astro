---
import MainLayout from '../layouts/MainLayout.astro';

const educationalInstitutions = [
  {
    name: "Old Dominion University",
    url: "https://www.odu.edu/",
    description: "Public research university in Norfolk."
  },
  {
    name: "Tidewater Community College",
    url: "https://www.tcc.edu/",
    description: "Community college with multiple campuses."
  },
  {
    name: "ECPI University",
    url: "https://www.ecpi.edu/",
    description: "Private university focused on technology."
  },
  {
    name: "Hampton University",
    url: "https://www.hamptonu.edu/",
    description: "Private research university in Hampton."
  }
];
---

<MainLayout
  title="Learning"
  description="Educational resources and institutions in Hampton Roads for growing your tech skills."
>
  <div class="container">
    <h1>Learning</h1>
    <p>Educational institutions in Hampton Roads with tech programs.</p>

    <h2>Educational institutions</h2>
    <ul class="learning-list">
      {educationalInstitutions.map((i) => (
        <li>
          <a href={i.url} target="_blank" rel="noopener noreferrer">{i.name}</a>
          {' '}&mdash; <span class="muted">{i.description}</span>
        </li>
      ))}
    </ul>

    <p class="muted">
      Know an online resource, bootcamp, or program that belongs here?
      <a href="https://github.com/RevolutionVA/757-community-site-public" target="_blank" rel="noopener noreferrer">Submit a PR</a>.
    </p>
  </div>
</MainLayout>

<style>
  .learning-list {
    list-style: none;
    padding: 0;
  }
  .learning-list li {
    margin-bottom: 0.35rem;
  }
</style>
