---
import MainLayout from '../layouts/MainLayout.astro';
import EventRow from '../components/EventRow.astro';
import calendarEvents from '../data/calendar-events.json';
import conferencesData from '../data/conferences.json';
import { formatShortDate, formatConfDate } from '../utils/formatDate';

// Types
interface CalendarEvent {
  title: string;
  link: string;
  date: string;
  description: string;
  source: string;
  group: string;
  featuredEvent?: boolean;
}

interface Conference {
  name: string;
  url: string;
  description: string;
  date: string;
  endDate?: string;
  location: string;
  tags: string[];
}

// This week's events
const today = new Date();
today.setHours(0, 0, 0, 0);
const oneWeekFromNow = new Date(today);
oneWeekFromNow.setDate(today.getDate() + 7);

const thisWeekEvents = calendarEvents
  .filter((event: CalendarEvent) => {
    const eventDate = new Date(event.date);
    const isFeatured = event.featuredEvent === true;
    return isFeatured || (eventDate >= today && eventDate <= oneWeekFromNow);
  })
  .sort((a: CalendarEvent, b: CalendarEvent) => {
    const aFeatured = a.featuredEvent === true;
    const bFeatured = b.featuredEvent === true;
    if (aFeatured && !bFeatured) return -1;
    if (!aFeatured && bFeatured) return 1;
    return new Date(a.date).getTime() - new Date(b.date).getTime();
  })
  .slice(0, 8);

// Conferences
const currentDate = new Date();
function parseLocalDate(dateString: string): Date {
  return new Date(dateString.includes('T') ? dateString : `${dateString}T12:00:00`);
}

const upcomingConferences = (conferencesData as Conference[])
  .filter(c => parseLocalDate(c.date) > currentDate)
  .sort((a, b) => parseLocalDate(a.date).getTime() - parseLocalDate(b.date).getTime())
  .slice(0, 3);


---

<MainLayout
  title="Home"
  description="757tech connects technology professionals in Hampton Roads, Virginia. Find local meetups, events, learning resources, and job opportunities in Virginia Beach, Norfolk, Chesapeake, and beyond."
  showHero={true}
>
  <div class="sec">this week in the 757</div>

  {thisWeekEvents.length > 0 ? (
    thisWeekEvents.map((event) => {
      const tags = [event.group];
      if (event.featuredEvent) tags.push('featured');
      return (
        <EventRow
          date={formatShortDate(event.date)}
          title={event.title}
          link={event.link}
          tags={tags}
          highlightedTags={event.featuredEvent ? ['featured'] : []}
        />
      );
    })
  ) : (
    <div class="row">
      <span class="dt"></span>
      <span class="ti">No meetups scheduled this week — check the full calendar</span>
      <span class="lo"></span>
    </div>
  )}

  <div class="more"><a href="/calendar">view full calendar &rarr;</a></div>

  {upcomingConferences.length > 0 && (
    <Fragment>
      <div class="sec">conferences</div>

      {upcomingConferences.map(conf => (
        <EventRow
          date={formatConfDate(conf.date)}
          title={conf.name}
          link={conf.url}
          tags={conf.tags.slice(0, 2)}
          location={conf.location}
        />
      ))}

      <div class="more"><a href="/conferences">all conferences &rarr;</a></div>
    </Fragment>
  )}

  <div class="sec">get involved</div>

  <div class="row">
    <span class="dt"></span>
    <span class="ti"><a href="/get-involved">Start a meetup, speak at an event, mentor someone, sponsor a conference</a><span class="tg"><span class="t">volunteer</span></span></span>
    <span class="lo"></span>
  </div>
  <div class="row">
    <span class="dt"></span>
    <span class="ti"><a href="https://github.com/RevolutionVA/757-community-site-public">Contribute to this site on GitHub — PRs welcome</a><span class="tg"><span class="t">open source</span></span></span>
    <span class="lo"></span>
  </div>
</MainLayout>
