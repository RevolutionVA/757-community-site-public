---
import MainLayout from '../layouts/MainLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';
import PathCard from '../components/PathCard.astro';
import IndustryCard from '../components/IndustryCard.astro';
import CompanyCard from '../components/CompanyCard.astro';
import ThisWeekMeetups from '../components/ThisWeekMeetups.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import industries from '../data/industries.json';
import companies from '../data/companies.json';

const featuredCompanies = [...companies]
  .filter((c) => c.type === 'company')
  .sort((a, b) => a.name.localeCompare(b.name))
  .slice(0, 8);
---

<MainLayout
  title="Home"
  description="757tech is the front door to tech in Hampton Roads — connecting developers, industry, and opportunity across the 757."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="mono-label">// 757tech</span>
        <h1>Front door to tech in Hampton Roads.</h1>
        <p>Connecting developers, industry, and opportunity across the 757.</p>
        <p class="hero-tagline">Beach. Bridges. Battleships. This is where 757 tech meets the real world.</p>
        <div class="btn-row">
          <a href="#paths" class="btn btn-primary">Explore paths</a>
          <a href="#happening" class="btn btn-secondary">What's happening</a>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <section id="paths" class="section">
      <SectionDivider title="Choose your path" />
      <div class="grid-4 paths-grid">
        <PathCard
          audience="Developer"
          tagline="Meetups, communities, and companies hiring engineers across the 757."
          href="/developers"
          accent="beach"
          label="developer"
        />
        <PathCard
          audience="Transitioning Military"
          tagline="Cyber pathways, training programs, and employers that hire cleared talent."
          href="/military-transition"
          accent="battleships"
          label="military"
        />
        <PathCard
          audience="Hiring / Company"
          tagline="Get on the directory. Reach builders. Show what you're building here."
          href="/companies"
          accent="bridges"
          label="hiring"
        />
        <PathCard
          audience="Startup / Builder"
          tagline="Programs, orgs, and events for founders and people shipping new things."
          href="/startups"
          accent="primary"
          label="builder"
        />
      </div>
    </section>

    <section id="happening" class="section">
      <SectionDivider title="What's happening" />
      <div class="happening-grid">
        <NewsletterSignup />
        <ThisWeekMeetups />
      </div>
    </section>

    <section class="section">
      <SectionDivider title="What's being built" />
      <p class="section-lead">
        Tech in the 757 is applied, real-world, and mission-driven. Ships, ports, hospitals, and operations — and the software running through all of it.
      </p>
      <div class="grid-3">
        {industries.map((industry) => (
          <IndustryCard
            id={industry.id}
            name={industry.name}
            blurb={industry.blurb}
            anchorOrgs={industry.anchorOrgs}
          />
        ))}
      </div>
    </section>

    <section class="section">
      <SectionDivider title="Who's building here" />
      <p class="section-lead">
        A starting list of companies and orgs operating in Hampton Roads. <a href="/companies">View the full directory →</a>
      </p>
      <div class="grid">
        {featuredCompanies.map((company) => (
          <CompanyCard {...company} />
        ))}
      </div>
    </section>

    <section class="section get-involved-section">
      <SectionDivider title="Get involved" />
      <div class="get-involved">
        <p>
          Run a meetup, speak at a conference, mentor someone, or just show up. The 757 is built by the people who keep showing up.
        </p>
        <a href="/get-involved" class="btn btn-primary">Find your way in</a>
      </div>
    </section>
  </div>
</MainLayout>

<style>
  .hero-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .hero-copy {
    max-width: 60ch;
  }

  .hero .mono-label {
    margin-bottom: var(--space-sm);
    display: inline-block;
  }

  .section-lead {
    color: var(--color-text-muted);
    max-width: 70ch;
    margin-bottom: var(--space-md);
    font-size: 1.0625rem;
  }

  .happening-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: var(--space-md);
    align-items: start;
  }

  @media (max-width: 900px) {
    .happening-grid {
      grid-template-columns: 1fr;
    }
  }

  .paths-grid {
    margin-bottom: var(--space-md);
  }

  .get-involved {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .get-involved p {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
  }
</style>
