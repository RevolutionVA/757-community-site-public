---
import MainLayout from '../layouts/MainLayout.astro';
import ThisWeekMeetups from '../components/ThisWeekMeetups.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<MainLayout
  title="Home"
  description="757tech connects technologists in Hampton Roads, Virginia. Find local meetups, events, learning resources, and job opportunities in Virginia Beach, Norfolk, Chesapeake, and beyond."
>
  <div class="container">
    <h1>757tech</h1>
    <p>
      A plain-text directory of tech meetups, events, and communities across Hampton Roads, Virginia:
      Virginia Beach, Norfolk, Chesapeake, Suffolk, Hampton, Newport News, and Williamsburg.
    </p>
    <p class="muted">
      New to the area? Start by scanning this week's events below, then browse the sections.
    </p>

    <h2>This week</h2>
    <ThisWeekMeetups />

    <h2>Browse</h2>
    <ul class="two-col-list">
      <li><a href="/meetups">Meetups</a> &mdash; local groups by category</li>
      <li><a href="/calendar">Full calendar</a> &mdash; all upcoming events</li>
      <li><a href="/conferences">Conferences</a> &mdash; regional tech conferences</li>
      <li><a href="/communities">Communities</a> &mdash; online and in-person</li>
      <li><a href="/learning">Learning</a> &mdash; schools and resources</li>
      <li><a href="/work">Work</a> &mdash; notable local employers</li>
      <li><a href="/get-involved">Get involved</a> &mdash; speak, organize, volunteer</li>
      <li><a href="https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ" target="_blank" rel="noopener noreferrer">Slack</a> &mdash; 757dev workspace</li>
      <li><a href="https://discord.gg/bPGsCKBqWp" target="_blank" rel="noopener noreferrer">Discord</a> &mdash; 757 tech chat</li>
      <li><a href="https://github.com/RevolutionVA/757-community-site-public" target="_blank" rel="noopener noreferrer">GitHub</a> &mdash; source &amp; submissions</li>
    </ul>

    <h2>Newsletter</h2>
    <p>Weekly email with upcoming local tech events. No spam.</p>
    <NewsletterSignup />

    <h2>New to the 757?</h2>
    <p>
      Most meetups are free and welcoming to newcomers. Show up, introduce yourself, and ask what
      people are working on. The best way to plug in is to attend one event this month, then keep
      coming back. See <a href="/get-involved">get involved</a> for ways to contribute beyond
      attending.
    </p>

    <p class="muted">
      Spot a missing event or group?
      <a href="https://github.com/RevolutionVA/757-community-site-public" target="_blank" rel="noopener noreferrer">Submit a PR on GitHub</a>.
    </p>
  </div>
</MainLayout>
