---
import MainLayout from '../layouts/MainLayout.astro';

const companies = [
  { name: "Marathon Consulting", location: "Virginia Beach", description: "IT consulting firm specializing in custom software development", url: "https://www.marathonus.com/" },
  { name: "Dominion Enterprises", location: "Norfolk", description: "Media and information services company", url: "https://www.dominionenterprises.com/" },
  { name: "STIHL Inc.", location: "Virginia Beach", description: "Manufacturer of outdoor power equipment", url: "https://www.stihlusa.com/" },
  { name: "LifeNet Health", location: "Virginia Beach", description: "Non-profit global leader in regenerative medicine", url: "https://www.lifenethealth.org/" },
  { name: "Issuetrak", location: "Virginia Beach", description: "Software company providing issue tracking and process management solutions", url: "https://www.issuetrak.com/" },
  { name: "Yellow Dog Software", location: "Norfolk", description: "Provider of inventory management systems for hospitality, sports, and retail markets", url: "https://www.yellowdogsoftware.com/" },
  { name: "Techark", location: "Norfolk", description: "Digital innovation company offering web development, software, and mobile app solutions", url: "https://gotechark.com/" },
  { name: "Decisions", location: "Virginia Beach", description: "No-code, rules-driven platform for business process automation", url: "https://decisions.com/" },
  { name: "MAXX Potential", location: "Norfolk & Richmond", description: "IT apprenticeship and staffing company providing tech talent solutions", url: "https://maxxpotential.com/" }
];

const sortedCompanies = [...companies].sort((a, b) => a.name.localeCompare(b.name));
---

<MainLayout
  title="Work"
  description="Find tech jobs and career opportunities in Hampton Roads, Virginia. Explore companies hiring developers, designers, and IT professionals."
>
  <div class="page-hero">
    <h1>Work</h1>
    <p>Notable tech companies in the Hampton Roads area.</p>
  </div>

  <div class="sec">tech companies</div>

  {sortedCompanies.map(company => (
    <div class="co">
      <div>
        <div class="cn"><a href={company.url} target="_blank" rel="noopener noreferrer">{company.name}</a></div>
        <div class="cd">{company.description}</div>
      </div>
      <span class="cc">{company.location}</span>
    </div>
  ))}
</MainLayout>
