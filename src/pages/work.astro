---
import MainLayout from '../layouts/MainLayout.astro';

const companies = [
  {
    name: "Marathon Consulting",
    location: "Virginia Beach",
    description: "IT consulting firm specializing in custom software development.",
    url: "https://www.marathonus.com/"
  },
  {
    name: "Dominion Enterprises",
    location: "Norfolk",
    description: "Media and information services company.",
    url: "https://www.dominionenterprises.com/"
  },
  {
    name: "STIHL Inc.",
    location: "Virginia Beach",
    description: "Manufacturer of outdoor power equipment.",
    url: "https://www.stihlusa.com/"
  },
  {
    name: "LifeNet Health",
    location: "Virginia Beach",
    description: "Non-profit global leader in regenerative medicine.",
    url: "https://www.lifenethealth.org/"
  },
  {
    name: "Issuetrak",
    location: "Virginia Beach",
    description: "Issue tracking and process management software.",
    url: "https://www.issuetrak.com/"
  },
  {
    name: "Yellow Dog Software",
    location: "Norfolk",
    description: "Inventory management systems for hospitality, sports, and retail.",
    url: "https://www.yellowdogsoftware.com/"
  },
  {
    name: "Techark",
    location: "Norfolk",
    description: "Digital innovation — web, software, and mobile app solutions.",
    url: "https://gotechark.com/"
  },
  {
    name: "Decisions",
    location: "Virginia Beach",
    description: "No-code, rules-driven platform for business process automation.",
    url: "https://decisions.com/"
  },
  {
    name: "MAXX Potential",
    location: "Norfolk & Richmond",
    description: "IT apprenticeship and staffing company.",
    url: "https://maxxpotential.com/"
  }
];

const sortedCompanies = [...companies].sort((a, b) => a.name.localeCompare(b.name));
---

<MainLayout
  title="Work"
  description="Notable tech employers in Hampton Roads, Virginia."
>
  <div class="container">
    <h1>Work</h1>
    <p>Notable tech employers in Hampton Roads, sorted alphabetically.</p>

    <h2>Notable tech companies</h2>
    <ul class="company-list">
      {sortedCompanies.map((c) => (
        <li>
          <a href={c.url} target="_blank" rel="noopener noreferrer">{c.name}</a>
          {' '}&mdash; <span class="muted">{c.location}</span>
          <div class="muted company-desc">{c.description}</div>
        </li>
      ))}
    </ul>

    <p class="muted">
      Know another tech employer hiring locally?
      <a href="https://github.com/RevolutionVA/757-community-site-public" target="_blank" rel="noopener noreferrer">Submit a PR</a>.
    </p>
  </div>
</MainLayout>

<style>
  .company-list {
    list-style: none;
    padding: 0;
  }
  .company-list > li {
    margin-bottom: 0.6rem;
  }
  .company-desc {
    font-size: 0.9rem;
    margin-top: 0.1rem;
  }
</style>
