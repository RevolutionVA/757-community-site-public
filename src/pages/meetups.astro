---
import MainLayout from '../layouts/MainLayout.astro';

import meetupsData from '../data/meetups-combined.json';

interface Meetup {
  name: string;
  url: string;
  tags: string[];
  category: string;
  rssFeed?: string;
  metadata: {
    imageUrl: string;
    title?: string;
    description?: string;
  };
}

const categories = ['Development', 'Cloud', 'Design', 'Technology'];
const meetupsByCategory: Record<string, Meetup[]> = {};
for (const cat of categories) {
  meetupsByCategory[cat] = (meetupsData as Meetup[])
    .filter(m => m.category === cat)
    .sort((a, b) => a.name.localeCompare(b.name));
}


---

<MainLayout
  title="Meetups"
  description="Discover technology meetups in Hampton Roads, Virginia. Connect with local developers, designers, and tech enthusiasts."
>
  <div class="page-hero">
    <h1>Meetups</h1>
    <p>Connect with the local tech community through regular meetups.
      <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/meetups-combined.json" target="_blank" rel="noopener noreferrer">Add a meetup</a>
      · <a href="/calendar">View upcoming events</a>
    </p>
  </div>

  {categories.map(cat => (
    <Fragment>
      <div class="sec">{cat}</div>
      {meetupsByCategory[cat].map(meetup => (
        <div class="co co-with-av">
          {meetup.metadata.imageUrl ? (
            <img class="co-av" src={meetup.metadata.imageUrl} alt="" width="150" height="90" loading="lazy" />
          ) : (
            <span class="co-av-text">{meetup.name.substring(0, 2)}</span>
          )}
          <div>
            <div class="cn"><a href={meetup.url} target="_blank" rel="noopener noreferrer">{meetup.name}</a></div>
            <div class="cd">{meetup.metadata.description || ''}</div>
          </div>
        </div>
      ))}
    </Fragment>
  ))}
</MainLayout>
