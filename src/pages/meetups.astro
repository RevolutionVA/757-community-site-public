---
import MainLayout from '../layouts/MainLayout.astro';
import meetupsData from '../data/meetups-combined.json';

interface Meetup {
  name: string;
  url: string;
  tags: string[];
  category: string;
  rssFeed?: string;
  metadata?: {
    imageUrl?: string;
    title?: string;
    description?: string;
  };
}

const categories = ['Development', 'Cloud', 'Design', 'Technology'];
const byCategory: Record<string, Meetup[]> = {};
for (const cat of categories) {
  byCategory[cat] = (meetupsData as Meetup[])
    .filter((m) => m.category === cat)
    .sort((a, b) => a.name.localeCompare(b.name));
}
---

<MainLayout
  title="Meetups"
  description="Technology meetups in Hampton Roads, Virginia. Local developer, designer, cloud, and tech groups in Virginia Beach, Norfolk, and surrounding areas."
>
  <div class="container">
    <h1>Meetups</h1>
    <p>Local tech meetups in Hampton Roads, grouped by category.</p>
    <p class="muted">
      Missing a group? <a href="https://github.com/RevolutionVA/757-community-site-public/blob/main/src/data/meetups-combined.json" target="_blank" rel="noopener noreferrer">Edit the data file on GitHub</a>.
      For upcoming events across all groups, see the <a href="/calendar">full calendar</a>.
    </p>

    {categories.map((cat) => (
      <>
        <h2>{cat}</h2>
        {byCategory[cat].length > 0 ? (
          <ul class="meetup-list">
            {byCategory[cat].map((m) => (
              <li>
                <a href={m.url} target="_blank" rel="noopener noreferrer">{m.name}</a>
                {m.tags.length > 0 && (
                  <> &mdash; <span class="muted">{m.tags.join(', ')}</span></>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="muted">(none listed)</p>
        )}
      </>
    ))}
  </div>
</MainLayout>

<style>
  .meetup-list {
    list-style: none;
    padding: 0;
  }

  .meetup-list li {
    margin-bottom: 0.3rem;
  }
</style>
