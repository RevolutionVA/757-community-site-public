---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Technology community in Hampton Roads, Virginia",
  image = "/images/757tech-social-card.jpg",
  canonicalUrl = Astro.url.pathname
} = Astro.props;

const siteUrl = "https://757tech.org";
const fullCanonicalUrl = `${siteUrl}${canonicalUrl}`;
const fullTitle = `${title} | 757 Tech Community`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonicalUrl} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteUrl}${image}`} />

    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Bento Tracking -->
    <script src="https://fast.bentonow.com?site_uuid=57d9b8196b2b704a30da5ac245bf2cfe&js=true" async defer></script>
    <script>
      if (typeof(bento$) != 'undefined') {
        bento$(function() {
          bento.view();
        });
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="logo">757tech</a>
        <nav>
          <ul>
            <li><a href="/meetups">meetups</a></li>
            <li><a href="/calendar">calendar</a></li>
            <li><a href="/conferences">conferences</a></li>
            <li><a href="/communities">communities</a></li>
            <li><a href="/learning">learning</a></li>
            <li><a href="/work">work</a></li>
            <li><a href="/get-involved">get involved</a></li>
            <li><a href="https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ" target="_blank" rel="noopener noreferrer">slack</a></li>
            <li><a href="https://discord.gg/bPGsCKBqWp" target="_blank" rel="noopener noreferrer">discord</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>
          Supported by <a href="https://revolutionva.org">RevolutionVA</a>
          (a 501c3 non-profit supporting developer education in Southeast Virginia).
          Built by <a href="https://www.linkedin.com/in/tedjpatterson/">Ted Patterson</a>
          and <a href="https://www.linkedin.com/in/1kevgriff">Kevin Griffin</a>.
        </p>
        <p>
          <a href="https://github.com/RevolutionVA/757-community-site-public" target="_blank" rel="noopener noreferrer">Contribute on GitHub</a> &mdash; submissions welcome.
        </p>
      </div>
    </footer>
  </body>
</html>
