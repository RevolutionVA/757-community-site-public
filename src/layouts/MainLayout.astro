---
import meetupsData from '../data/meetups-combined.json';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  showHero?: boolean;
}

const {
  title,
  description = "Technology community in Hampton Roads, Virginia",
  image = "/images/757tech-social-card.jpg",
  canonicalUrl = Astro.url.pathname,
  showHero = false
} = Astro.props;

const siteUrl = "https://757tech.org";
const fullCanonicalUrl = `${siteUrl}${canonicalUrl}`;
const fullTitle = `${title} | 757 Tech Community`;

// Group meetups by category for left sidebar
const categories = ['Development', 'Cloud', 'Design', 'Technology'];
const meetupsByCategory: Record<string, typeof meetupsData> = {};
for (const cat of categories) {
  meetupsByCategory[cat] = meetupsData
    .filter(m => m.category === cat)
    .sort((a, b) => a.name.localeCompare(b.name));
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonicalUrl} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${siteUrl}${image}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,600;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="/styles/global.css" />

    <script src="https://fast.bentonow.com?site_uuid=57d9b8196b2b704a30da5ac245bf2cfe&js=true" async defer></script>
    <script>
      if (typeof(bento$) != 'undefined') {
        bento$(function() {
          bento.view();
        });
      }
    </script>
  </head>
  <body>

    <!-- HEADER -->
    <div class="hdr">
      <div class="hdr-left">
        <a href="/" class="logo"><b>757</b>tech</a>
        <span class="tagline">the landing page for hampton roads technologists</span>
      </div>
      <div class="hdr-right">
        <a href="https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ">slack</a>
        <a href="https://discord.gg/bPGsCKBqWp">discord</a>
        <a href="https://github.com/RevolutionVA/757-community-site-public">github</a>
      </div>
    </div>

    <!-- HERO (homepage only) -->
    {showHero && (
      <div class="hero">
        <h1>the <span class="em">landing page</span> for hampton roads technologists</h1>
        <p>developers, designers, data people, infosec pros, cloud engineers, and everyone building things with technology in the 757. find your meetup. find your people.</p>
        <div class="hero-stats">
          <div class="hero-stat"><span class="num">40k+</span>tech professionals</div>
          <div class="hero-stat"><span class="num">~20</span>monthly meetups</div>
          <div class="hero-stat"><span class="num">{meetupsData.length}</span>active groups</div>
          <div class="hero-stat"><span class="num">200</span>beach days/yr</div>
        </div>
      </div>
    )}

    <!-- NAV -->
    <div class="nav">
      <a href="/meetups">meetups</a><span class="sep">|</span>
      <a href="/calendar">calendar</a><span class="sep">|</span>
      <a href="/conferences">conferences</a><span class="sep">|</span>
      <a href="/learning">learning</a><span class="sep">|</span>
      <a href="/work">work</a><span class="sep">|</span>
      <a href="/get-involved">get involved</a>
    </div>

    <!-- 3-COL LAYOUT -->
    <div class="wrap">

      <!-- LEFT SIDEBAR: Meetup Groups -->
      <div class="sb-l">
        {categories.map(cat => (
          <Fragment>
            <h3>{cat}</h3>
            <ul>
              {meetupsByCategory[cat].map(meetup => (
                <li><a href={meetup.url}>{meetup.name}</a></li>
              ))}
            </ul>
          </Fragment>
        ))}
      </div>

      <!-- CENTER -->
      <main class="main">
        <slot />
      </main>

      <!-- RIGHT SIDEBAR -->
      <div class="sb-r">

        <!-- Newsletter -->
        <form
          action="https://track.bentonow.com/forms/57d9b8196b2b704a30da5ac245bf2cfe/$subscribe757tech?hardened=true"
          method="POST"
          enctype="multipart/form-data"
          class="newsletter"
          onkeydown="if(event.keyCode === 13) { event.preventDefault(); this.submit(); }"
        >
          <h4>Stay Connected</h4>
          <p>Weekly updates on local tech events, conferences & opportunities</p>
          <input type="hidden" name="redirect" value="https://757tech.org/newsletter-thank-you" />
          <input type="email" name="email" placeholder="you@email.com" required />
          <button type="submit">subscribe</button>
          <div class="disclosure">We may send occasional newsletters about events and partners. Unsubscribe anytime.</div>
        </form>

        <h3>Get Connected</h3>
        <ul>
          <li><a href="https://join.slack.com/t/757dev/shared_invite/zt-37d031yip-yI9z3ez8ezf~mJTy5ICaeQ">757dev Slack</a></li>
          <li><a href="https://discord.gg/bPGsCKBqWp">757dev Discord</a></li>
          <li><a href="https://github.com/RevolutionVA/757-community-site-public">GitHub</a></li>
        </ul>

        <p class="note">
          757tech is the landing page for technologists in Virginia Beach, Norfolk, Chesapeake, Suffolk, Hampton, Newport News, Williamsburg & the greater Hampton Roads region. Supported by <a href="https://revolutionva.org">RevolutionVA</a>.
        </p>
      </div>

    </div>

    <!-- FOOTER -->
    <div class="ftr">
      <div class="ftr-links">
        <a href="/meetups">meetups</a>
        <a href="/calendar">calendar</a>
        <a href="/conferences">conferences</a>
        <a href="/learning">learning</a>
        <a href="/work">work</a>
        <a href="/get-involved">get involved</a>
      </div>
      supported by <a href="https://revolutionva.org">RevolutionVA</a> (501c3)
      · built by <a href="https://www.linkedin.com/in/1kevgriff">Kevin Griffin</a> &amp; <a href="https://www.linkedin.com/in/tedjpatterson/">Ted Patterson</a>
      · <a href="https://github.com/RevolutionVA/757-community-site-public">contribute on GitHub</a>
    </div>

  </body>
</html>
