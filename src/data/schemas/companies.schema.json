{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Companies",
  "description": "Schema for companies and orgs in the 757tech directory",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "url", "description", "location", "industries", "type"],
    "properties": {
      "name": {
        "type": "string",
        "description": "Company or organization name"
      },
      "url": {
        "type": "string",
        "pattern": "^https?://[^\\s/$.?#].[^\\s]*$",
        "description": "Primary website URL"
      },
      "description": {
        "type": "string",
        "minLength": 10,
        "description": "One-line description of what the org does locally"
      },
      "location": {
        "type": "string",
        "description": "City or region within Hampton Roads"
      },
      "industries": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": [
            "defense-cyber",
            "maritime",
            "health",
            "logistics",
            "ai-software"
          ]
        },
        "description": "Industry ids matching src/data/industries.json"
      },
      "type": {
        "type": "string",
        "enum": ["company", "org", "startup"],
        "description": "company = for-profit employer; org = community/nonprofit; startup = early-stage builder"
      },
      "hiring": {
        "type": "boolean",
        "description": "Currently hiring tech roles"
      },
      "hiringClearedTalent": {
        "type": "boolean",
        "description": "Hires cleared talent (relevant for transitioning military)"
      },
      "logoUrl": {
        "type": "string",
        "description": "Optional logo path or URL"
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "additionalProperties": false
  }
}
