---
import WaveDivider from "./WaveDivider.astro";
import { catColor } from "./utils";

export interface HeroEvent {
  url: string;
  category: string;
  dow: string;
  day: string;
  mon: string;
  timeLabel: string;
  group: string;
  title: string;
}
interface Props { nextEvent?: HeroEvent | null; }
const { nextEvent } = Astro.props;
const c = nextEvent ? catColor(nextEvent.category) : null;
---
<section class="hero hero-split" id="top">
  <div class="hero-split-grid">
    <div class="hero-copy">
      <h1>The front door to tech<br />in the <span class="hl">757</span></h1>
      <p class="hero-sub">Every meetup, user group, and regional conference in the 757 — in one tide. Get the weekly digest and never miss what's happening.</p>
      <form class="capture light" data-hero-capture>
        <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
        <button type="submit">Get the digest</button>
      </form>
      <div class="hero-mini">Free · weekly · unsubscribe anytime</div>
    </div>
    <div class="hero-peek">
      <div class="peek-label">Next up this week</div>
      {nextEvent && c && (
        <a class="next-card" href={nextEvent.url} target="_blank" rel="noopener noreferrer">
          <div class="next-date" style={`background:${c.bg};color:${c.fg}`}>
            <span class="nd-dow">{nextEvent.dow}</span>
            <span class="nd-day">{nextEvent.day}</span>
            <span class="nd-mon">{nextEvent.mon}</span>
          </div>
          <div class="next-body">
            <span class="cat-badge" style={`background:${c.bg};color:${c.fg};font-size:11px`}>
              <span class="cat-dot" style={`background:${c.dot}`}></span>{nextEvent.category}
            </span>
            <div class="next-group">{nextEvent.group}</div>
            <div class="next-title">{nextEvent.title}</div>
            <div class="next-meta">{nextEvent.timeLabel}</div>
          </div>
        </a>
      )}
      {!nextEvent && (
        <p class="next-title">No upcoming events on the calendar right now — check back soon.</p>
      )}
      <a class="peek-all" href="#events">See all upcoming events →</a>
    </div>
  </div>
  <WaveDivider />
</section>

<script>
  // Inline hero capture is a teaser for the real Bento form: prefill + scroll.
  const form = document.querySelector("[data-hero-capture]") as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value || "";
    const target = document.getElementById("news-email") as HTMLInputElement | null;
    if (target) target.value = email;
    document.getElementById("subscribe")?.scrollIntoView({ behavior: "smooth", block: "start" });
    const focusField = (document.getElementById("news-fname") || target) as HTMLInputElement | null;
    window.setTimeout(() => focusField?.focus(), 600);
  });
</script>
