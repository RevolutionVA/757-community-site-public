---
import UrlImage from './UrlImage.astro';

interface Props {
  title: string;
  href: string;
  image?: string;
  coverImage?: string;
  useDynamicImage?: boolean;
  showMetadata?: boolean;
  hideTitle?: boolean;
}

const {
  title,
  href,
  image,
  coverImage,
  useDynamicImage = false,
  showMetadata = false,
  hideTitle = false
} = Astro.props;

const displayImage = coverImage || image;
const shouldHideTitle = hideTitle || (showMetadata && useDynamicImage);
---

<div class="card">
  {useDynamicImage ? (
    <UrlImage
      url={href}
      title={title}
      fallbackImage={displayImage}
      showMetadata={showMetadata}
    />
  ) : displayImage && (
    <a href={href} target="_blank" rel="noopener noreferrer" class="image-link">
      <img src={displayImage} alt={title} loading="lazy" />
    </a>
  )}
  {!shouldHideTitle && (
    <h3><a href={href} target="_blank" rel="noopener noreferrer">{title}</a></h3>
  )}
  <slot />
</div>

<style>
  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    background-color: var(--color-surface);
    margin-bottom: 1.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
  }

  .card img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
    object-fit: cover;
    aspect-ratio: 16/9;
    max-height: 150px;
  }

  .image-link {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
  }

  .card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.0625rem;
  }

  .card h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .card h3 a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
