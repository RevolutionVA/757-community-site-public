---
import HiringBadge from './HiringBadge.astro';

interface Props {
  name: string;
  url: string;
  description: string;
  location: string;
  industries?: string[];
  type?: "company" | "org" | "startup";
  hiring?: boolean;
  hiringClearedTalent?: boolean;
}

const {
  name,
  url,
  description,
  location,
  industries = [],
  type = "company",
  hiring = false,
  hiringClearedTalent = false
} = Astro.props;
---

<article class="company-card">
  <header class="company-header">
    <h3 class="company-name">
      <a href={url} target="_blank" rel="noopener noreferrer">{name}</a>
    </h3>
    {hiring && <HiringBadge cleared={hiringClearedTalent} />}
  </header>
  <p class="company-location">{location}</p>
  <p class="company-description">{description}</p>
  {industries.length > 0 && (
    <ul class="company-industries">
      {industries.map((id) => <li>{id.replace("-", " · ")}</li>)}
    </ul>
  )}
</article>

<style>
  .company-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .company-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
  }

  .company-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .company-name {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.3;
  }

  .company-name a {
    color: var(--color-text);
    text-decoration: none;
  }

  .company-name a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .company-location {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-subtle);
    margin-bottom: 0.5rem;
  }

  .company-description {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .company-industries {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: auto 0 0;
  }

  .company-industries li {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    background-color: var(--color-surface-alt);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.55rem;
    border: 1px solid var(--color-border);
  }
</style>
