---
import calendarEvents from '../data/calendar-events.json';

interface CalendarEvent {
  title: string;
  link: string;
  date: string;
  description: string;
  source: string;
  group: string;
  featuredEvent?: boolean;
  createdDate?: string;
  updatedDate?: string;
}

// Helpers for America/New_York timezone arithmetic.
// We key everything off the ET calendar date (YYYY-MM-DD) so DST and the
// user's local timezone never shift which "day" an event belongs to.
function getETParts(date: Date) {
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    weekday: 'short',
  }).formatToParts(date);
  const get = (t: string) => parts.find((p) => p.type === t)?.value ?? '';
  return {
    year: get('year'),
    month: get('month'),
    day: get('day'),
    weekday: get('weekday'), // "Mon", "Tue", etc.
    iso: `${get('year')}-${get('month')}-${get('day')}`,
  };
}

function addDaysToISO(iso: string, days: number): string {
  const [y, m, d] = iso.split('-').map(Number);
  const dt = new Date(Date.UTC(y, m - 1, d));
  dt.setUTCDate(dt.getUTCDate() + days);
  const ny = dt.getUTCFullYear();
  const nm = String(dt.getUTCMonth() + 1).padStart(2, '0');
  const nd = String(dt.getUTCDate()).padStart(2, '0');
  return `${ny}-${nm}-${nd}`;
}

function formatDayHeading(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  const dt = new Date(Date.UTC(y, m - 1, d, 12, 0, 0));
  return dt.toLocaleDateString('en-US', {
    timeZone: 'America/New_York',
    weekday: 'long',
    month: 'short',
    day: 'numeric',
  });
}

function formatEventTime(dateString: string): string {
  const d = new Date(dateString);
  return d
    .toLocaleTimeString('en-US', {
      timeZone: 'America/New_York',
      hour: 'numeric',
      minute: '2-digit',
    })
    .replace(/\s/g, '')
    .toLowerCase(); // "6:30pm"
}

function formatFeaturedDate(dateString: string): string {
  const d = new Date(dateString);
  return d.toLocaleDateString('en-US', {
    timeZone: 'America/New_York',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

// Compute Monday..Sunday ISO dates for the current ET week.
const now = new Date();
const todayParts = getETParts(now);
const weekdayMap: Record<string, number> = { Sun: 0, Mon: 1, Tue: 2, Wed: 3, Thu: 4, Fri: 5, Sat: 6 };
const todayWeekdayNum = weekdayMap[todayParts.weekday] ?? 1;
const daysFromMonday = todayWeekdayNum === 0 ? 6 : todayWeekdayNum - 1;
const mondayISO = addDaysToISO(todayParts.iso, -daysFromMonday);
const weekISOs: string[] = [];
for (let i = 0; i < 7; i++) {
  weekISOs.push(addDaysToISO(mondayISO, i));
}
const sundayISO = weekISOs[6];
const weekSet = new Set(weekISOs);

// Bucket events into this-week and outside-week-featured.
type Event = CalendarEvent & { _etISO: string };
const annotated: Event[] = (calendarEvents as CalendarEvent[]).map((e) => ({
  ...e,
  _etISO: getETParts(new Date(e.date)).iso,
}));

const thisWeekEvents = annotated
  .filter((e) => weekSet.has(e._etISO))
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const featuredOutsideWeek = annotated
  .filter((e) => e.featuredEvent === true && !weekSet.has(e._etISO))
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

// Group this-week events by ET day.
const eventsByDay: Record<string, Event[]> = {};
for (const iso of weekISOs) eventsByDay[iso] = [];
for (const e of thisWeekEvents) eventsByDay[e._etISO].push(e);

const todayISO = todayParts.iso;
---

{featuredOutsideWeek.length > 0 && (
  <div class="featured-events">
    <h3>Featured</h3>
    <ul class="day-events">
      {featuredOutsideWeek.map((event) => (
        <li>
          <span class="event-time">{formatFeaturedDate(event.date)}</span>{' '}
          <a href={event.link} target="_blank" rel="noopener noreferrer">{event.title}</a>
          {' '}&mdash; <span class="muted">{event.group}</span>
        </li>
      ))}
    </ul>
  </div>
)}

<div class="this-week-meetups">
  {weekISOs.map((iso) => {
    const dayEvents = eventsByDay[iso];
    const isToday = iso === todayISO;
    return (
      <div class="day-block">
        <h3 class="day-heading">
          {formatDayHeading(iso)}
          {isToday && <span class="muted"> (today)</span>}
        </h3>
        {dayEvents.length > 0 ? (
          <ul class="day-events">
            {dayEvents.map((event) => (
              <li>
                <span class="event-time">{formatEventTime(event.date)}</span>{' '}
                <a href={event.link} target="_blank" rel="noopener noreferrer">{event.title}</a>
                {' '}&mdash; <span class="muted">{event.group}</span>
                {event.featuredEvent === true && <span class="featured-tag"> [featured]</span>}
              </li>
            ))}
          </ul>
        ) : (
          <p class="muted">(no events)</p>
        )}
      </div>
    );
  })}

  <p class="view-all"><a href="/calendar">View full calendar &rarr;</a></p>
</div>

<style>
  .featured-events {
    margin-bottom: 1rem;
  }

  .day-block {
    margin-bottom: 0.75rem;
  }

  .day-heading {
    margin-top: 1rem;
    margin-bottom: 0.25rem;
  }

  .day-events {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .day-events li {
    margin: 0.15rem 0;
  }

  .event-time {
    display: inline-block;
    min-width: 4.5rem;
    color: #666;
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    font-size: 0.85rem;
  }

  .featured-tag {
    color: #663300;
    font-size: 0.8rem;
    font-weight: bold;
  }

  .view-all {
    margin-top: 1rem;
  }
</style>
