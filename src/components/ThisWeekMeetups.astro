---
import calendarEvents from '../data/calendar-events.json';

interface CalendarEvent {
  title: string;
  link: string;
  date: string;
  description: string;
  source: string;
  group: string;
  featuredEvent?: boolean;
  createdDate?: string;
  updatedDate?: string;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const oneWeekFromNow = new Date(today);
oneWeekFromNow.setDate(today.getDate() + 7);

const thisWeekEvents = calendarEvents
  .filter((event: CalendarEvent) => {
    const eventDate = new Date(event.date);
    const isFeatured = (event as any).featuredEvent === true;
    return isFeatured || (eventDate >= today && eventDate <= oneWeekFromNow);
  })
  .sort((a: CalendarEvent, b: CalendarEvent) => {
    const aFeatured = (a as any).featuredEvent === true;
    const bFeatured = (b as any).featuredEvent === true;

    if (aFeatured && !bFeatured) return -1;
    if (!aFeatured && bFeatured) return 1;

    return new Date(a.date).getTime() - new Date(b.date).getTime();
  });

function formatEventDate(dateString: string) {
  const date = new Date(dateString);
  const dayOfWeek = date.toLocaleDateString('en-US', { weekday: 'short', timeZone: 'America/New_York' });
  const month = date.toLocaleDateString('en-US', { month: 'short', timeZone: 'America/New_York' });
  const dayOfMonth = date.toLocaleDateString('en-US', { day: 'numeric', timeZone: 'America/New_York' });
  const time = date.toLocaleTimeString('en-US', {
    hour: 'numeric',
    minute: '2-digit',
    timeZone: 'America/New_York'
  });
  return `${dayOfWeek}, ${month} ${dayOfMonth} · ${time}`;
}
---

<div class="this-week-meetups">
  <h3>Upcoming Meetups</h3>

  {thisWeekEvents.length > 0 ? (
    <ul class="event-list">
      {thisWeekEvents.map((event) => {
        const isFeatured = (event as any).featuredEvent === true;
        return (
          <li class={`event-item ${isFeatured ? 'featured-event' : ''}`}>
            {isFeatured && <div class="featured-badge">Featured</div>}
            <div class="event-date" title={formatEventDate(event.date)}>{formatEventDate(event.date)}</div>
            <div class="event-details">
              <a href={event.link} target="_blank" rel="noopener noreferrer" class="event-title">
                {event.title}
              </a>
              <div class="event-group">{event.group}</div>
            </div>
          </li>
        );
      })}
    </ul>
  ) : (
    <p class="no-events">No meetups scheduled for this week.</p>
  )}

  <div class="view-all">
    <a href="/calendar" class="view-all-link">View all upcoming events →</a>
  </div>
</div>

<style>
  .this-week-meetups {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1.75rem;
    border-radius: var(--radius-lg);
  }

  .this-week-meetups h3 {
    margin-top: 0;
    color: var(--color-text);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .event-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .event-item {
    display: flex;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
    position: relative;
  }

  .event-item:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .featured-event {
    background-color: var(--color-surface-alt);
    border-left: 3px solid var(--color-beach);
    padding: 0.75rem 1rem;
    margin-left: -1rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .featured-badge {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background-color: var(--color-beach);
    color: var(--color-surface-dark);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .event-date {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    margin-right: 1rem;
    min-width: 180px;
  }

  .event-details {
    flex: 1;
    min-width: 0;
  }

  .event-title {
    display: block;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 0.25rem;
    font-size: 0.9375rem;
  }

  .event-title:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .event-group {
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .no-events {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .view-all {
    margin-top: 1rem;
    text-align: right;
  }

  .view-all-link {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .view-all-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .event-item {
      flex-direction: column;
    }

    .event-date {
      flex: 0 0 auto;
      margin-bottom: 0.5rem;
      margin-right: 0;
      min-width: unset;
    }

    .event-details {
      flex: 1 0 100%;
    }

    .featured-badge {
      position: static;
      display: inline-block;
      margin-bottom: 0.5rem;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .event-date {
      min-width: 160px;
    }
  }
</style>
